# Only needed for live quote data (price, day change, 52w high/low, volume).
# Company search and all fundamentals (EPS, ROE, cash flow, ...) work without
# any of these — see README.md.

# Option A: paste a daily Access Token from Groww > Settings > Trading APIs
GROWW_ACCESS_TOKEN=

# Option B: API Key + Secret (auto-generates a token, still needs daily
# approval on the Groww Cloud API Keys page)
GROWW_API_KEY=
GROWW_API_SECRET=

# ── Only needed for run_daily.py (the headless automation / GitHub Actions
# workflow) — the interactive UI (server.py) never uses these. ──────────────

# Vector store embeddings (vector_store.py) AND the LLM narrative email
# (emailer.py) both use Gemini. Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash   # optional override

# Digest email delivery via Gmail SMTP. EMAIL_FROM needs a 16-character App
# Password (not your normal password) — generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification on
# that Google account). EMAIL_TO can be the same address as EMAIL_FROM.
EMAIL_FROM=
EMAIL_APP_PASSWORD=
EMAIL_TO=
