# Only needed for live quote data (price, day change, 52w high/low, volume).
# Company search and all fundamentals (EPS, ROE, cash flow, ...) work without
# any of these — see README.md.

# Option A: paste a daily Access Token from Groww > Settings > Trading APIs
GROWW_ACCESS_TOKEN=

# Option B: API Key + Secret (auto-generates a token, still needs daily
# approval on the Groww Cloud API Keys page)
GROWW_API_KEY=
GROWW_API_SECRET=
