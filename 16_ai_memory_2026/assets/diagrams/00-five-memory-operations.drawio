  <diagram id="five-ops" name="The five universal memory operations">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1160" pageHeight="320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="The five universal memory operations" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontColor=#15141F;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="640" height="30" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="1 &#183; Store&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;write a new memory&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2 &#183; Retrieve&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;find relevant memories for a query&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="270" y="120" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3 &#183; Update&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;revise a memory when new info contradicts it&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="500" y="120" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="4 &#183; Compress&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;summarize / consolidate redundant memories&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#E2F5F1;strokeColor=#0F8F7E;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="740" y="120" width="200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="5 &#183; Forget&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;prune stale or low-value memories&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="980" y="120" width="150" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4B32D9;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="n1" target="n2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4B32D9;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="n2" target="n3">
          <mxGeometry relative="1" as="geometry" />
