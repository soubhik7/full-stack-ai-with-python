          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e45" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F8F7E;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="n4" target="n5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e52" value="freed capacity, cleaner signal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B5540C;strokeWidth=1.5;dashed=1;dashPattern=3 3;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#B5540C;exitX=0.5;exitY=1;entryX=0.5;entryY=1;" edge="1" parent="1" source="n5" target="n2">
