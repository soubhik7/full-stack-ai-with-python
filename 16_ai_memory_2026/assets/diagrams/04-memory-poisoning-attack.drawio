        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B5540C;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="attacker" target="agent1">
