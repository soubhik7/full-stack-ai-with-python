<mxfile host="app.diagrams.net" agent="claude-code" version="24.7.0">
  <diagram id="poisoning-attack" name="Memory poisoning attack chain">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

