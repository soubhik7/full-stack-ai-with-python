          <mxGeometry x="20" y="10" width="640" height="30" as="geometry" />
        </mxCell>

        <mxCell id="attacker" value="Attacker&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#84341E&quot;&gt;crafted input with a memory-write trigger&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="agent1" value="Agent&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#514F68&quot;&gt;remember() persists the poisoned content as if it were legitimate&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="210" height="90" as="geometry" />
        </mxCell>
        <mxCell id="mem" value="Memory store&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#84341E&quot;&gt;poisoned memory looks identical to genuine ones — no session boundary to expire it&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="550" y="140" width="220" height="110" as="geometry" />
        </mxCell>

