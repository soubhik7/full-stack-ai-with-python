        <mxCell id="act" value="Agent acts on the attacker's instructions / false facts" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#1C1A2B;strokeColor=#B5540C;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
