          <mxGeometry x="830" y="40" width="380" height="320" as="geometry" />
        </mxCell>
        <mxCell id="recall" value="recall() retrieves the poisoned memory alongside legitimate ones" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="850" y="80" width="340" height="70" as="geometry" />
        </mxCell>
        <mxCell id="inject" value="Poisoned content injected into context, treated as trusted" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontSize=11;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="850" y="170" width="340" height="70" as="geometry" />
