<mxfile host="app.diagrams.net" agent="claude-code" version="24.7.0">
  <diagram id="temporal-graph" name="Temporal knowledge graph — Graphiti / Zep">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1080" pageHeight="360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Bi-temporal graph: facts are invalidated, never deleted" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontColor=#15141F;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="conv" value="Conversation episode&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#514F68&quot;&gt;&quot;I'm moving to Berlin next month&quot;&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#F7F7FB;strokeColor=#DCDBE9;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="30" y="130" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="llm" value="LLM extractor" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=13;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="280" y="150" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="newedge" value="NEW EDGE&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#514F68&quot;&gt;(user) -[LIVES_IN]-&gt; Berlin&lt;br&gt;t_valid = next month, t_invalid = open&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#E2F5F1;strokeColor=#0F8F7E;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="oldedge" value="EXISTING EDGE&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#514F68&quot;&gt;(user) -[LIVES_IN]-&gt; Paris&lt;br&gt;NOT deleted &#8212; invalidated: t_invalid = now&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontStyle=1;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="qcurrent" value="Query: &quot;where does the user live?&quot;&lt;br&gt;&#8594; &lt;b&gt;Berlin&lt;/b&gt; (current)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#1C1A2B;strokeColor=#4B32D9;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="830" y="50" width="230" height="80" as="geometry" />
        </mxCell>
        <mxCell id="qtime" value="Query: &quot;where did they live in March?&quot;&lt;br&gt;&#8594; &lt;b&gt;Paris&lt;/b&gt; (time-travel)" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#1C1A2B;strokeColor=#B5540C;strokeWidth=2;fontColor=#FFFFFF;fontSize=12;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="830" y="230" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4B32D9;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="conv" target="llm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="creates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F8F7E;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#514F68;exitX=1;exitY=0.3;" edge="1" parent="1" source="llm" target="newedge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="invalidates" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B5540C;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#514F68;exitX=1;exitY=0.7;" edge="1" parent="1" source="llm" target="oldedge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F8F7E;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="newedge" target="qcurrent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B5540C;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;" edge="1" parent="1" source="oldedge" target="qtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
