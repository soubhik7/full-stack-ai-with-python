                <mxCell id="core" value="CORE MEMORY&lt;br&gt;&lt;font style=&quot;font-size:11px;font-weight:normal;color:#514F68&quot;&gt;like RAM — always in-context, small, fast, always visible to the LLM on every turn&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#1C1A2B;strokeColor=#4B32D9;strokeWidth=2;fontColor=#FFFFFF;fontStyle=1;fontSize=13;fontFamily=Helvetica;" parent="1" vertex="1">
