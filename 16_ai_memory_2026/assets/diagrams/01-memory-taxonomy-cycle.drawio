        <mxCell id="e-sem-proc" value="repeated successful strategies generalize" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#0F8F7E;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#514F68;exitX=0.5;exitY=1;entryX=1;entryY=0.3;" edge="1" parent="1" source="sem" target="proc">
          <mxGeometry relative="1" as="geometry" />
