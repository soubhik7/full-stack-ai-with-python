  <diagram id="taxonomy-cycle" name="Episodic / semantic / procedural cycle">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="760" pageHeight="440" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="An agent's memory, by function" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontColor=#15141F;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="500" height="30" as="geometry" />
        </mxCell>

        <mxCell id="ep" value="EPISODIC&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;'what happened' — session logs, decision records, past traces&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#ECE9FC;strokeColor=#4B32D9;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="sem" value="SEMANTIC&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;'what is true' — facts, preferences, world knowledge&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#E2F5F1;strokeColor=#0F8F7E;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="proc" value="PROCEDURAL&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#514F68&quot;&gt;'how to do it' — reusable skills, learned strategies&lt;/font&gt;" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#FBEADB;strokeColor=#B5540C;strokeWidth=1.5;fontColor=#15141F;fontSize=13;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="270" y="290" width="220" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e-ep-sem" value="consolidation extracts stable facts" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#4B32D9;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#514F68;exitX=1;exitY=0.3;entryX=0;entryY=0.3;" edge="1" parent="1" source="ep" target="sem">
          <mxGeometry relative="1" as="geometry" />
