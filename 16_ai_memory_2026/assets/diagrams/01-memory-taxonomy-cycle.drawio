        <mxCell id="e-proc-ep" value="executing a skill generates new episodes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#B5540C;strokeWidth=2;dashed=1;dashPattern=4 4;flowAnimation=1;endArrow=block;endFill=1;fontSize=10;fontColor=#514F68;exitX=0;entryX=0.5;entryY=1;exitY=0.3;" edge="1" parent="1" source="proc" target="ep">
